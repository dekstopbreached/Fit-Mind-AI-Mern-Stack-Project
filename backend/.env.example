# Backend environment variables for FitMind AI
MONGO_URI=mongodb://<username>:<password>@<host>:27017/<database>?authSource=admin
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=7d
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: use OpenAI instead by switching AI_PROVIDER=openai and setting OPENAI_API_KEY
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4.1-mini
PORT=8000
